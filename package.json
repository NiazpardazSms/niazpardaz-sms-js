{
  "name": "niazpardazsms",
  "version": "1.0.2",
  "description": "کتابخانه رسمی JavaScript/TypeScript برای کار با پنل پیامکی نیازپرداز",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sms",
    "niazpardaz",
    "نیازپرداز",
    "پیامک",
    "iran",
    "persian",
    "farsi",
    "otp",
    "bulk-sms",
    "sms-gateway",
    "nodejs",
    "typescript",
    "javascript",
    "react",
    "nextjs",
    "angular",
    "nuxtjs",
    "nestjs"
  ],
  "author": "Niazpardaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiazpardazSms/niazpardaz-sms-js.git"
  },
  "bugs": {
    "url": "https://github.com/NiazpardazSms/niazpardaz-sms-js/issues"
  },
  "homepage": "https://niazpardaz-sms.com",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "axios": ">=0.21.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  }
}
